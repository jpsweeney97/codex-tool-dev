{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sora-promptify-output",
  "type": "object",
  "required": [
    "mode"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "CLARIFY",
        "FINAL"
      ]
    },
    "clarifying_questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "clarifying_reply_hint": {
      "type": "string"
    },
    "sora_app_settings": {
      "type": "object",
      "required": [
        "orientation",
        "duration_seconds"
      ],
      "properties": {
        "orientation": {
          "type": "string",
          "enum": [
            "portrait_9_16"
          ]
        },
        "duration_seconds": {
          "type": "integer",
          "enum": [
            15
          ]
        },
        "style": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "sora_prompt": {
      "type": "string",
      "minLength": 1
    },
    "mitigations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remix_nudges": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "CLARIFY"
          }
        }
      },
      "then": {
        "required": [
          "clarifying_questions",
          "clarifying_reply_hint"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "sora_app_settings"
              ]
            },
            {
              "required": [
                "sora_prompt"
              ]
            },
            {
              "required": [
                "mitigations"
              ]
            },
            {
              "required": [
                "remix_nudges"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "FINAL"
          }
        }
      },
      "then": {
        "required": [
          "sora_app_settings",
          "sora_prompt",
          "mitigations",
          "remix_nudges"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "clarifying_questions"
              ]
            },
            {
              "required": [
                "clarifying_reply_hint"
              ]
            }
          ]
        }
      }
    }
  ],
  "additionalProperties": false
}
