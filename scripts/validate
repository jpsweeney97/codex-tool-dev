#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(_ROOT))

from scripts.lib.validate_entry import parse_validate_args, validate  # noqa: E402


def _repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def main(argv: list[str]) -> int:
    root = _repo_root()
    kind, name = parse_validate_args(argv)
    failures = validate(kind=kind, name=name, repo_root=root)

    if failures:
        for item in failures:
            print(item, file=sys.stderr)
        return 2

    print("validate: ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
