#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(_ROOT))

from scripts.lib.codex_home import codex_home  # noqa: E402
from scripts.lib.manifest import InstallManifest  # noqa: E402
from scripts.lib.promote import (  # noqa: E402
    promote_agent,
    promote_automation_template,
    promote_skill,
)
from scripts.lib.validate_entry import validate  # noqa: E402


def _repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="scripts/promote")
    sub = parser.add_subparsers(dest="kind", required=True)

    parser_skill = sub.add_parser("skill", help="Promote a skill into /Users/jp/.codex.")
    parser_skill.add_argument("name", help="Skill directory name under .codex/skills/")

    parser_agent = sub.add_parser("agent", help="Promote an agent into /Users/jp/.codex.")
    parser_agent.add_argument("name", help="Agent filename without extension under .codex/agents/")

    parser_automation = sub.add_parser(
        "automation", help="Promote an automation template into /Users/jp/.codex."
    )
    parser_automation.add_argument("name", help="Template filename without extension under .codex/automations/templates/")

    parser_all = sub.add_parser("all", help="Promote all artifacts.")

    args = parser.parse_args(argv)
    root = _repo_root()
    home = codex_home()

    # Validate first.
    if args.kind == "all":
        failures = validate("all", None, repo_root=root)
    elif args.kind == "skill":
        failures = validate("skill", args.name, repo_root=root)
    elif args.kind == "agent":
        failures = validate("agent", args.name, repo_root=root)
    elif args.kind == "automation":
        failures = validate("automation", args.name, repo_root=root)
    else:
        raise ValueError(f"promote failed: unknown kind. Got: {args.kind!r}")

    if failures:
        for item in failures:
            print(item, file=sys.stderr)
        return 2

    manifest = InstallManifest.load_or_create(home / "install-manifest.toml")

    if args.kind == "skill":
        promote_skill(
            src_dir=root / ".codex" / "skills" / args.name,
            dest_root=home / "skills",
            manifest=manifest,
        )
    elif args.kind == "agent":
        promote_agent(
            src_file=root / ".codex" / "agents" / f"{args.name}.md",
            dest_root=home / "agents",
            manifest=manifest,
        )
    elif args.kind == "automation":
        promote_automation_template(
            src_template=root / ".codex" / "automations" / "templates" / f"{args.name}.toml.tmpl",
            dest_root=home / "automations",
            manifest=manifest,
        )
    elif args.kind == "all":
        for skill_dir in (root / ".codex" / "skills").iterdir():
            if skill_dir.is_dir():
                promote_skill(skill_dir, home / "skills", manifest)
        for agent_file in (root / ".codex" / "agents").glob("*.md"):
            promote_agent(agent_file, home / "agents", manifest)
        for template in (root / ".codex" / "automations" / "templates").glob("*.toml.tmpl"):
            promote_automation_template(template, home / "automations", manifest)
    else:
        raise AssertionError(f"promote failed: unreachable branch. Got: {args.kind!r}")

    manifest.save()
    print(f"promote: ok -> {home}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
