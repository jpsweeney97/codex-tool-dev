#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
python_bin="$repo_root/.venv/bin/python"

if [[ ! -x "$python_bin" ]]; then
  echo "scripts/python failed: missing venv python. Got: ${python_bin:.100}" 1>&2
  echo "Create it in a normal Terminal with: uv sync --group dev" 1>&2
  echo "Fallback (no uv): python3 -m venv .venv && .venv/bin/pip install -e '.[eval]'" 1>&2
  exit 2
fi

exec "$python_bin" "$@"
