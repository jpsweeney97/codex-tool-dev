#!/usr/bin/env -S /Users/jp/Projects/active/codex-tool-dev/scripts/python
from __future__ import annotations

import argparse
import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(_ROOT))

from scripts.lib.jsonl_schema import validate_jsonl_against_schema  # noqa: E402


def _repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="scripts/validate_sora_evals")
    parser.add_argument(
        "--eval-root",
        type=Path,
        default=_repo_root() / "evals" / "sora_promptify",
        help="Path to eval root (contains variants.jsonl + schema).",
    )
    args = parser.parse_args(argv)

    variants_jsonl = args.eval_root / "variants.jsonl"
    variants_schema = args.eval_root / "variants.schema.json"

    failures = validate_jsonl_against_schema(
        jsonl_path=variants_jsonl,
        schema_path=variants_schema,
    )
    if failures:
        for item in failures:
            print(item, file=sys.stderr)
        return 2

    print("validate sora evals: ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
