#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(_ROOT))

from scripts.lib.scenario_runner import run_scenarios  # noqa: E402


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="scripts/test")
    parser.add_argument(
        "--kind",
        choices=["skills", "agents", "all"],
        default="all",
        help="Which scenarios to run.",
    )
    args = parser.parse_args(argv)

    repo_root = Path(__file__).resolve().parents[1]
    scenarios_root = repo_root / "tests" / "scenarios"

    if args.kind == "skills":
        kinds = ["skills"]
    elif args.kind == "agents":
        kinds = ["agents"]
    else:
        kinds = ["skills", "agents"]

    failures = run_scenarios(scenarios_root=scenarios_root, kinds=kinds)
    if failures:
        for item in failures:
            print(item, file=sys.stderr)
        return 2
    print("test: ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))

