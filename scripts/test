#!/usr/bin/env -S /Users/jp/Projects/active/codex-tool-dev/scripts/python
from __future__ import annotations

import argparse
import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(_ROOT))


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="scripts/test")
    parser.add_argument(
        "--kind",
        choices=["skills", "agents", "evals", "all"],
        default="all",
        help="Which scenarios to run.",
    )
    args = parser.parse_args(argv)

    repo_root = Path(__file__).resolve().parents[1]
    scenarios_root = repo_root / "tests" / "scenarios"

    # Note: scenario runner depends on PyYAML. Prefer a clear error over a stack trace.
    try:
        from scripts.lib.scenario_runner import run_scenarios  # type: ignore[import-not-found]
    except ModuleNotFoundError as e:
        if e.name in ("yaml", "pyyaml"):
            print(
                "scripts/test failed: missing dependency 'pyyaml'. "
                "Install project deps (e.g. `uv sync`) to run scenario tests.",
                file=sys.stderr,
            )
            return 2
        raise

    if args.kind == "skills":
        kinds = ["skills"]
    elif args.kind == "agents":
        kinds = ["agents"]
    elif args.kind == "evals":
        kinds = ["evals"]
    else:
        kinds = ["skills", "agents", "evals"]

    failures = run_scenarios(scenarios_root=scenarios_root, kinds=kinds)
    if failures:
        for item in failures:
            print(item, file=sys.stderr)
        return 2
    print("test: ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
